pipeline {
    agent any

    options {
        skipDefaultCheckout(false)
        timestamps()
    }

    environment {
        CI = 'true'
    }

    stages {

        stage('Checkout Source Code') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('automation') {
                    bat 'npm ci'
                }
            }
        }

        stage('Install Playwright Browsers') {
            steps {
                dir('automation') {
                    bat 'npx playwright install --with-deps'
                }
            }
        }

        stage('Run Playwright Tests') {
            steps {
                dir('automation') {
                    bat 'npx playwright test'
                }
            }
        }

        stage('Generate Report') {
            steps {
                dir('automation') {
                    bat 'npx playwright show-report || exit 0'
                }
            }
        }

        stage('Archive Reports & Results') {
            steps {
                archiveArtifacts artifacts: 'automation/playwright-report/**', allowEmptyArchive: true
                archiveArtifacts artifacts: 'automation/test-results/**', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished.'
        }

        success {
            echo '✅ Playwright tests passed successfully.'
        }

        failure {
            echo '❌ Playwright tests failed.'
        }
    }
}