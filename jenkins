pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
        timestamps()
    }

    environment {
        CI = 'true'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Validate Branch') {
            steps {
                script {
                    echo "Running on branch: ${env.BRANCH_NAME}"

                    if (env.BRANCH_NAME != 'main') {
                        error("❌ Pipeline allowed only on main branch. Current: ${env.BRANCH_NAME}")
                    }
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('automation') {
                    bat 'npm ci'
                }
            }
        }

        stage('Install Playwright Browsers') {
            steps {
                dir('automation') {
                    bat 'npx playwright install --with-deps'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('automation') {
                    bat 'npx playwright test'
                }
            }
        }

        stage('Archive Reports') {
            steps {
                archiveArtifacts artifacts: 'automation/playwright-report/**', allowEmptyArchive: true
                archiveArtifacts artifacts: 'automation/test-results/**', allowEmptyArchive: true
            }
        }

        stage('Zip Report') {
            steps {
                bat 'powershell Compress-Archive -Path automation\\playwright-report\\* -DestinationPath automation\\playwright-report.zip -Force'
            }
        }
    }

    post {

        success {
            echo "✅ Build SUCCESS"
            echo "Job: ${env.JOB_NAME}"
            echo "Build: ${env.BUILD_NUMBER}"
            echo "URL: ${env.BUILD_URL}"
        }

        failure {
            echo "❌ Build FAILED"
            echo "Job: ${env.JOB_NAME}"
            echo "Build: ${env.BUILD_NUMBER}"
            echo "URL: ${env.BUILD_URL}"
        }

        always {
            echo "Pipeline execution completed."
        }
    }
}