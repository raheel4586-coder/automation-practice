pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
        timestamps()
    }

    environment {
        CI = 'true'
    }

    stages {

        stage('Validate Branch') {
            steps {
                script {
                    echo "Branch: ${env.BRANCH_NAME}"

                    if (env.BRANCH_NAME != 'main') {
                        error("❌ Pipeline allowed only on main branch. Current: ${env.BRANCH_NAME}")
                    }
                }
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('automation') {
                    bat 'npm ci'
                }
            }
        }

        stage('Install Playwright Browsers') {
            steps {
                dir('automation') {
                    bat 'npx playwright install --with-deps'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('automation') {
                    bat 'npx playwright test'
                }
            }
        }

        stage('Archive Reports') {
            steps {
                archiveArtifacts artifacts: 'automation/playwright-report/**', allowEmptyArchive: true
                archiveArtifacts artifacts: 'automation/test-results/**', allowEmptyArchive: true
            }
        }

        stage('Zip Report') {
            steps {
                bat 'powershell Compress-Archive -Path automation\\playwright-report\\* -DestinationPath automation\\playwright-report.zip -Force'
            }
        }
    }

    post {

        success {
            emailext (
                subject: "✅ SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Build SUCCESS 🎉

Job: ${env.JOB_NAME}
Build: ${env.BUILD_NUMBER}
URL: ${env.BUILD_URL}

📊 Report:
${env.BUILD_URL}artifact/automation/playwright-report/index.html
                """,
                to: "mukraheel@gmail.com",
                attachmentsPattern: 'automation/playwright-report.zip'
            )
        }

        failure {
            emailext (
                subject: "❌ FAILURE: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Build FAILED ❌

Job: ${env.JOB_NAME}
Build: ${env.BUILD_NUMBER}
URL: ${env.BUILD_URL}

📊 Check Report:
${env.BUILD_URL}artifact/automation/playwright-report/index.html
                """,
                to: "mukraheel@gmail.com",
                attachmentsPattern: 'automation/playwright-report.zip'
            )
        }

        always {
            echo "Pipeline execution completed."
        }
    }
}